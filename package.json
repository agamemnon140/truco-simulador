{
  "name": "truco-simulador",
  "version": "0.1.0",
  "description": "Simulador do jogo de truco (Paulista), com motor de regras configuravel",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli/main.ts",
    "demo": "tsx src/cli/demo.ts",
    "demo:verbose": "tsx src/cli/verbose-demo.ts",
    "demo:onze": "tsx src/cli/maoonze-demo.ts",
    "demo:explica": "tsx src/cli/explain-demo.ts",
    "build:web": "node scripts/build-web.mjs",
    "train": "tsx src/training/train.ts",
    "train:rr": "tsx src/training/train-rr.ts",
    "train:rr4": "tsx src/training/train-rr4.ts",
    "train:rr5": "tsx src/training/train-rr5.ts",
    "evaluate": "tsx src/training/evaluate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["truco", "card-game", "simulador"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

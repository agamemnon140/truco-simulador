{
  "name": "truco-simulador",
  "version": "0.1.0",
  "description": "Simulador do jogo de truco (Paulista), com motor de regras configuravel",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli/main.ts",
    "demo": "tsx src/cli/demo.ts",
    "demo:verbose": "tsx src/cli/verbose-demo.ts",
    "demo:onze": "tsx src/cli/maoonze-demo.ts",
